<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/azatnet_background"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/tv_header_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_spacing_dp16"
        android:layout_marginTop="@dimen/padding_spacing_dp16"
        android:layout_marginEnd="@dimen/padding_spacing_dp8"
        android:ellipsize="end"
        android:fontFamily="@font/montserrat_bold"
        android:maxLines="1"
        android:text="@string/app_name"
        android:textColor="@color/azatnet_text_primary"
        android:textSize="24sp"
        app:layout_constraintEnd_toStartOf="@id/btn_profile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/btn_profile"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="@dimen/padding_spacing_dp16"
        android:layout_marginEnd="@dimen/padding_spacing_dp16"
        android:background="@drawable/bg_profile_circle_surface"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="@string/profile_content_desc"
            app:srcCompat="@drawable/ic_profile_person_white" />
    </FrameLayout>

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrier_header_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="tv_header_title,btn_profile" />

    <LinearLayout
        android:id="@+id/layout_connection_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_spacing_dp16"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="@dimen/padding_spacing_dp16"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/barrier_header_bottom">

        <View
            android:id="@+id/view_status_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_status_dot_red" />

        <TextView
            android:id="@+id/tv_test_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/montserrat_regular"
            android:text="@string/connection_not_connected"
            android:textColor="@color/azatnet_text_primary"
            android:textSize="16sp"
            tools:text="Не подключено" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fab"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_connect_circle_disconnected"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_connection_status">

        <ImageView
            android:id="@+id/iv_connect_icon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            app:srcCompat="@drawable/ic_power_white_56" />

        <TextView
            android:id="@+id/tv_connect_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="22dp"
            android:fontFamily="@font/montserrat_regular"
            android:gravity="center"
            android:text="@string/fab_connect"
            android:textAllCaps="true"
            android:textColor="@color/azatnet_text_primary"
            android:textSize="11sp" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_server_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_spacing_dp16"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="@dimen/padding_spacing_dp16"
        android:fontFamily="@font/montserrat_regular"
        android:gravity="center"
        android:text="Германия · Frankfurt"
        android:textColor="@color/azatnet_text_primary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fab" />

    <LinearLayout
        android:id="@+id/layout_stats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_spacing_dp16"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="@dimen/padding_spacing_dp16"
        android:baselineAligned="false"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_server_name">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/padding_spacing_dp8"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/azatnet_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_spacing_dp16">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_regular"
                    android:text="@string/label_speed"
                    android:textColor="@color/azatnet_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_speed_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/montserrat_regular"
                    android:text="—"
                    android:textColor="@color/azatnet_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_spacing_dp8"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/azatnet_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_spacing_dp16">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_regular"
                    android:text="@string/label_ping"
                    android:textColor="@color/azatnet_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_ping_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/montserrat_regular"
                    android:text="—"
                    android:textColor="@color/azatnet_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_activation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_spacing_dp16"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="@dimen/padding_spacing_dp16"
        android:backgroundTint="@color/azatnet_surface"
        android:fontFamily="@font/montserrat_regular"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minHeight="48dp"
        android:text="@string/btn_enter_activation_code"
        android:textAllCaps="false"
        android:textColor="@color/azatnet_text_primary"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_stats"
        app:strokeWidth="0dp" />

    <LinearLayout
        android:id="@+id/row_telegram"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_spacing_dp16"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="@dimen/padding_spacing_dp16"
        android:background="@drawable/bg_surface_rounded_12"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/padding_spacing_dp16"
        android:paddingTop="12dp"
        android:paddingEnd="@dimen/padding_spacing_dp16"
        android:paddingBottom="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_activation">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            app:srcCompat="@drawable/ic_send_plane" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fontFamily="@font/montserrat_regular"
            android:text="@string/telegram_channel_row_title"
            android:textColor="@color/azatnet_text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_footer_bar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginBottom="@dimen/padding_spacing_dp16"
        android:background="@drawable/bg_main_footer_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/padding_spacing_dp16"
        android:paddingEnd="@dimen/padding_spacing_dp16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/row_telegram">

        <TextView
            android:id="@+id/tv_footer_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/montserrat_regular"
            android:gravity="start|center_vertical"
            android:padding="@dimen/padding_spacing_dp8"
            android:text="@string/title_settings"
            android:textColor="@color/azatnet_footer_muted"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_footer_about"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/montserrat_regular"
            android:gravity="end|center_vertical"
            android:padding="@dimen/padding_spacing_dp8"
            android:text="@string/title_about"
            android:textColor="@color/azatnet_footer_muted"
            android:textSize="12sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
